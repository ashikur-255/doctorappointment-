<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- ========================= -->
  <!-- ENTITY FRAMEWORK -->
  <!-- ========================= -->
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <!-- ========================= -->
  <!-- DATABASE CONNECTION -->
  <!-- ========================= -->
  <connectionStrings>
    <add name="DefaultConnection" connectionString="Data Source=DESKTOP-DGOE82L\SQL2022;Initial Catalog=DoctorAppointmentSystem;User Id=ashikur;Password=ashikur@01" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <!-- ========================= -->
  <!-- APP SETTINGS -->
  <!-- ========================= -->
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- EMAIL -->
    <add key="Email" value="ashikurr255@gmail.com" />
