@model DoctorAppointmentSystem.Models.Appointment

@{
    ViewBag.Title = "Appointment Details";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="bi bi-calendar-check"></i> Appointment Details
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-secondary">
                    Doctor
                </div>

                <div class="col-md-8 text-primary fw-semibold">
                    @Model.Doctor.Name
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-secondary">
                    Patient
                </div>

                <div class="col-md-8">
                    @Model.Patient.Name
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-secondary">
                    Appointment Date
                </div>

                <div class="col-md-8">
                    @Model.AppointmentDate.ToString("dd MMM yyyy  hh:mm tt")
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold text-secondary">
                    Status
                </div>

                <div class="col-md-8">

                    @if (Model.IsConfirmed)
                    {
                        <span class="badge bg-success px-3 py-2">
                            Confirmed
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">
                            Pending
                        </span>
                    }

                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between">

                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>

                <a href="@Url.Action("Edit", new { id = Model.Id })"
                   class="btn btn-primary">
                    <i class="bi bi-pencil-square"></i> Edit Appointment
                </a>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}