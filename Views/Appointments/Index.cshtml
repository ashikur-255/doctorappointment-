@model PagedList.IPagedList<DoctorAppointmentSystem.Models.Appointment>

@{
    ViewBag.Title = "Appointments";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="card shadow-lg border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center bg-primary text-white rounded">
            <h3 class="mb-0">
                <i class="bi bi-calendar-check"></i> Appointment Management
            </h3>
            <a href="@Url.Action("Create")" class="btn btn-light btn-lg">
                <i class="bi bi-plus-circle"></i> ✚ New Appointment
            </a>
        </div>
    </div>

    <!-- SEARCH & FILTER -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-center">

                <div class="col-md-4">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-primary text-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control"
                               placeholder="Search Doctor, Patient or Phone..." />
                    </div>
                </div>

                <div class="col-md-3">
                    <select id="statusFilter" class="form-select form-select-lg">
                        <option value="">All Status</option>
                        <option value="confirmed">Confirmed</option>
                        <option value="pending">Pending</option>
                    </select>
                </div>

                <div class="col-md-5 text-end">
                    <button id="resetBtn" class="btn btn-secondary btn-lg">Reset</button>
                </div>

            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div id="appointmentTableContainer">
        @Html.Partial("_AppointmentsTable", Model)
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    function loadAppointments(page = 1, sortOrder = null) {

        var search = $("#searchInput").val();
        var status = $("#statusFilter").val();

        $.ajax({
            url: '@Url.Action("Index")',
            type: 'GET',
            data: {
                search: search,
                status: status,
                sortOrder: sortOrder,
                page: page
            },
            success: function (result) {

                var html = $(result).find("#appointmentTableContainer").html();
                $("#appointmentTableContainer").html(html);
            }
        });
    }

    $(document).ready(function () {

        // 🔍 SEARCH
        $("#searchInput").on("keyup", function () {
            loadAppointments();
        });

        // 📌 FILTER
        $("#statusFilter").on("change", function () {
            loadAppointments();
        });

        // 🔄 RESET
        $("#resetBtn").click(function () {
            $("#searchInput").val('');
            $("#statusFilter").val('');
            loadAppointments();
        });

        // 📄 PAGINATION
        $(document).on("click", ".page-link", function (e) {
            e.preventDefault();
            var page = $(this).data("page");
            loadAppointments(page);
        });

        // 🔃 SORT
        $(document).on("click", ".sort-link", function (e) {
            e.preventDefault();
            var sortOrder = $(this).data("sort");
            loadAppointments(1, sortOrder);
        });

    });

</script>