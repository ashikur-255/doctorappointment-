@model DoctorAppointmentSystem.Models.Appointment

@{
    ViewBag.Title = "Delete Appointment";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-trash3"></i> Delete Appointment
            </h4>
        </div>

        <div class="card-body">
            <h5 class="text-warning">
                Are you sure you want to delete this appointment?
            </h5>

            <hr />

            <dl class="row">
                <dt class="col-sm-3">Doctor</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Doctor.Name)</dd>

                <dt class="col-sm-3">Patient</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Patient.Name)</dd>

                <dt class="col-sm-3">Appointment Date</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.AppointmentDate)</dd>

                <dt class="col-sm-3">Confirmed</dt>
                <dd class="col-sm-9">
                    @if (Model.IsConfirmed)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </dd>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="d-flex justify-content-between mt-4">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3-fill"></i> Delete Appointment
                    </button>
                </div>
            }
        </div>
    </div>
</div>