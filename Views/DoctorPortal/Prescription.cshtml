@model DoctorAppointmentSystem.Models.Appointment

@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<h3>Prescription</h3>

<div class="card p-4 shadow">

    <h4>Patient Information</h4>

    <p><b>Name:</b> @Model.Patient.Name</p>

    <p><b>Age:</b> @Model.Patient.Age</p>

    <p><b>Disease:</b> @Model.Patient.DiseaseDetails</p>

    <hr>

    <h4>Prescription</h4>

<textarea class="form-control" rows="6"
          placeholder="Write medicines and instructions here"></textarea>

    <br>

    <button onclick="window.print()" class="btn btn-success">
        Print Prescription
    </button>

</div>