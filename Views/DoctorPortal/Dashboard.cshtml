@model IEnumerable<DoctorAppointmentSystem.Models.Appointment>

@{
    ViewBag.Title = "Doctor Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background: linear-gradient(135deg, #e3f2fd, #fce4ec);
    }

    .dashboard-header {
        background: rgba(255,255,255,0.7);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 15px 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
        border: none;
    }

    table tbody tr {
        transition: all 0.3s ease;
    }

        table tbody tr:hover {
            transform: scale(1.01);
            background-color: #f1faff;
        }

    .visit-btn {
        transition: all 0.3s ease;
        border-radius: 30px;
    }

        .visit-btn:hover {
            background: linear-gradient(45deg, #28a745, #20c997);
            transform: scale(1.1);
            box-shadow: 0 5px 15px rgba(40,167,69,0.4);
        }

    .logout-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 5px 15px rgba(220,53,69,0.4);
    }

    .counter-box {
        background: linear-gradient(45deg, #0d6efd, #00c6ff);
        color: white;
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="dashboard-header d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-primary mb-0">
            👨‍⚕️ Honorable⠨ @ViewBag.DoctorName Dashboard
        </h4>

        <a href="@Url.Action("Logout", "DoctorPortal")"
           class="btn btn-danger btn-sm logout-btn">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

    <!-- COUNTER -->
    <div class="counter-box mb-4 d-flex align-items-center justify-content-between">
        <div>
            <i class="bi bi-people-fill fs-4"></i>
            <span class="ms-2">Today's Confirmed Patients</span>
        </div>
        <h4 id="counter" class="mb-0">@ViewBag.TotalPatients</h4>
    </div>

    <!-- TABLE -->
    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Phone</th>
                        <th>Age</th>
                        <th>Disease</th>
                        <th>Status</th>
                        <th>Time</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int serial = 1;
                        foreach (var item in Model.OrderBy(a => a.AppointmentDate))
                        {
                            <tr id="row_@item.Id" class="text-center">
                                <td>@serial</td>
                                <td><b>@(item.Patient?.Name ?? "N/A")</b></td>
                                <td>@(item.Patient?.Phone ?? "N/A")</td>
                                <td>@(item.Patient?.Age.ToString() ?? "N/A")</td>
                                <td>@(item.Patient?.DiseaseDetails ?? "N/A")</td>

                                <td>
                                    <span class="badge bg-success px-3 py-2">
                                        Confirmed
                                    </span>
                                </td>

                                <td>@item.AppointmentDate.ToString("hh:mm tt")</td>

                                <td>
                                    <button class="btn btn-success btn-sm visit-btn">
                                        <i class="bi bi-check-circle"></i> Visit
                                    </button>
                                </td>
                            </tr>
                            serial++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-danger p-4">
                                🚫 No patients found for today
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@Html.AntiForgeryToken()

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).on("click", ".visit-btn", function () {

        let button = $(this);
        let id = button.closest("tr").attr("id").split("_")[1];

        Swal.fire({
            title: "Are you sure?",
            text: "Mark this patient as visited?",
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#28a745",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, mark visited!"
        }).then((result) => {

            if (result.isConfirmed) {

                Swal.fire({
                    title: 'Processing...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading()
                    }
                });

                $.ajax({
                    url: '@Url.Action("MarkVisited", "DoctorPortal")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken:
                            $('input[name="__RequestVerificationToken"]').val()
                    },

                    success: function (res) {

                        Swal.close();

                        if (res.success) {

                            $("#row_" + id).fadeOut(400, function () {
                                $(this).remove();
                            });

                            let counter = $("#counter");
                            counter.text(Math.max(0,
                                parseInt(counter.text()) - 1));

                            Swal.fire({
                                icon: "success",
                                title: "Visited!",
                                text: "Patient marked successfully",
                                timer: 1500,
                                showConfirmButton: false
                            });

                        } else {
                            Swal.fire("Error!", res.message, "error");
                        }
                    },

                    error: function () {
                        Swal.fire("Error!", "Something went wrong!", "error");
                    }
                });
            }
        });
    });
</script>