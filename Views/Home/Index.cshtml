<style>

    /* HERO */

    .hero-section {
        background: linear-gradient(rgba(13,110,253,0.85),rgba(111,66,193,0.85)), url('/Images/Back.jpg');
        background-size: cover;
        background-position: center;
        min-height: 420px;
        display: flex;
        align-items: center;
    }



    /* SEARCH */

    .search-box {
        max-width: 600px;
        margin: auto;
        position: relative;
    }

        .search-box i {
            position: absolute;
            top: 50%;
            left: 15px;
            transform: translateY(-50%);
            color: #777;
        }

        .search-box input {
            padding-left: 40px;
            height: 50px;
            border-radius: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }



    /* FILTER */

    .filter-btn {
        border: none;
        padding: 8px 18px;
        margin: 5px;
        border-radius: 25px;
        background: #eee;
        transition: .3s;
    }

        .filter-btn.active,
        .filter-btn:hover {
            background: #0d6efd;
            color: white;
        }



    /* DOCTOR CARD */

    .doctor-card {
        border-radius: 18px;
        transition: .35s;
    }

        .doctor-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    .doctor-img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #f1f1f1;
    }

    .slots .badge {
        margin: 2px;
    }
</style>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

    const searchInput = document.getElementById("doctorSearch");
    const doctors = document.querySelectorAll(".doctor-item");
    const filters = document.querySelectorAll(".filter-btn");

    let selectedSpec = "";


    function filterDoctors() {

        let search = searchInput.value.toLowerCase();

        doctors.forEach(doc => {

            let name = doc.getAttribute("data-name");
            let spec = doc.getAttribute("data-specialization");

            let matchName = name.includes(search);
            let matchSpec = selectedSpec == "" || spec == selectedSpec;

            doc.style.display = (matchName && matchSpec) ? "block" : "none";

        });

    }


    searchInput.addEventListener("keyup", filterDoctors);


    filters.forEach(btn => {

        btn.addEventListener("click", function () {

            filters.forEach(b => b.classList.remove("active"));

            this.classList.add("active");

            selectedSpec = this.getAttribute("data-filter");

            filterDoctors();

        });

    });


