@model IEnumerable<DoctorAppointmentSystem.Models.Doctor>

@{
    ViewBag.Title = "Home";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<!-- HERO -->
<section class="hero-section text-white text-center">

    <div class="container">

        <h1 class="display-4 fw-bold mb-3">
            Find the Best Doctors Near You
        </h1>

        <p class="lead mb-4">
            Book appointments with top specialists instantly.
        </p>

        <a href="@Url.Action("Create","Appointments")"
           class="btn btn-light btn-lg shadow">
            <i class="bi bi-calendar-check"></i> Book Appointment
        </a>

    </div>

</section>



<section class="container py-5">

    <h2 class="text-center text-primary fw-bold mb-4">
        Our Medical Specialists
    </h2>


    <!-- SEARCH -->
    <div class="search-box mb-4">

        <i class="bi bi-search"></i>

        <input type="text"
               id="doctorSearch"
               class="form-control"
               placeholder="Search doctor by name...">

    </div>


    <!-- FILTER -->
    <div class="text-center mb-4">

        <button class="filter-btn active" data-filter="">All</button>

        @foreach (var spec in Model
        .Where(d => d.Specialization != null)
        .Select(d => d.Specialization.Name)
        .Distinct())
        {
            <button class="filter-btn" data-filter="@spec">@spec</button>
        }

    </div>


    <div class="row">

        @foreach (var doctor in Model)
        {

            <div class="col-lg-3 col-md-4 col-sm-6 mb-4 doctor-item"
                 data-name="@doctor.Name.ToLower()"
                 data-specialization="@(doctor.Specialization!=null?doctor.Specialization.Name:"")">

                <div class="card doctor-card text-center border-0 shadow h-100">

                    <div class="card-body">

                        <img src="@(!string.IsNullOrEmpty(doctor.ImagePath)?Url.Content(doctor.ImagePath):Url.Content("~/Images/Doctors/default.png"))"
                             class="doctor-img mb-3">

                        <h5 class="fw-bold">@doctor.Name</h5>

                        <p class="text-muted">
                            @(doctor.Specialization!=null?doctor.Specialization.Name:"No Specialization")
                        </p>


                        <!-- RATING -->
                        <div class="rating mb-2">

                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-half text-warning"></i>

                            <span class="small text-muted">(4.5)</span>

                        </div>


                        <!-- AVAILABLE TIME -->
                        @*<div class="slots mb-3">

                            <span class="badge bg-success">10:00 AM</span>
                            <span class="badge bg-success">12:30 PM</span>
                            <span class="badge bg-success">03:00 PM</span>

                        </div>*@


                        <a href="@Url.Action("Details","Doctors",new{id=doctor.Id})"
                           class="btn btn-outline-primary btn-sm">
                            View Profile
                        </a>

                        @*<button class="btn btn-primary btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#appointmentModal"
                                data-doctor="@doctor.Name">
                            Quick Book
                        </button>*@

                    </div>

                </div>

            </div>

        }

    </div>

</section>



