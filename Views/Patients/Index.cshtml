@model PagedList.IPagedList<DoctorAppointmentSystem.Models.Patient>
@using PagedList.Mvc

@{
    ViewBag.Title = "Patients";
}

<div class="container mt-4">

    <!-- ===== PAGE HEADER ===== -->
    <div class="card shadow border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center"
             style="background:linear-gradient(135deg,#0d6efd,#6f42c1);color:white;">
            <div>
                <h3 class="mb-0"><i class="bi bi-people-fill"></i> Patients Management</h3>
                <small>Manage patient information</small>
            </div>
            @Html.ActionLink("✚ Add Patient", "Create", null, new { @class = "btn btn-light" })
        </div>
    </div>

    <!-- ===== SEARCH FILTER ===== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">
            <i class="bi bi-funnel"></i> Search & Filters
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Search Patient</label>
                    <input type="text" name="search" id="searchInput" class="form-control"
                           placeholder="Search by Name, Phone, Email, Disease..." />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="button" class="btn btn-secondary" onclick="resetFilter()">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- ===== PATIENT TABLE (AJAX) ===== -->
    <div id="patientTableContainer">
        @Html.Partial("_PatientsTable", Model)
    </div>

</div>

<!-- ===== JAVASCRIPT FOR AJAX LIVE SEARCH ===== -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function loadPatients(page = 1) {
        var search = $('#searchInput').val();

        $.ajax({
            url: '@Url.Action("Index", "Patients")',
            data: { search: search, page: page },
            success: function (result) {
                var html = $(result).find("#patientTableContainer").html();
                $("#patientTableContainer").html(html);
            }
        });
    }

    function resetFilter() {
        $('#searchInput').val('');
        loadPatients();
    }

    $(document).ready(function () {
        // live search
        $('#searchInput').on("keyup", function () {
            loadPatients();
        });

        // handle pagination click
        $(document).on("click", ".page-link", function (e) {
            e.preventDefault();
            var page = $(this).data("page") || $(this).attr("href").split('page=')[1];
            loadPatients(page);
        });
    });
</script>