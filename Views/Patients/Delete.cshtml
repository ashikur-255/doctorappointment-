@model DoctorAppointmentSystem.Models.Patient

@{
    ViewBag.Title = "Delete Patient";
}

<div class="container mt-5">
    <div class="card shadow-sm rounded">

        <div class="card-header bg-danger text-white">
            <h3><i class="bi bi-trash"></i> Confirm Delete</h3>
        </div>

        <div class="card-body">

            <p class="fs-5 text-warning">
                Are you sure you want to delete this patient?
            </p>

            <dl class="row mt-3">

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Age</dt>
                <dd class="col-sm-9">@Model.Age</dd>

                <dt class="col-sm-3">Gender</dt>
                <dd class="col-sm-9">@Model.Gender</dd>

                <dt class="col-sm-3">Blood Group</dt>
                <dd class="col-sm-9">@Model.BloodGroup</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Disease Details</dt>
                <dd class="col-sm-9">@Model.DiseaseDetails</dd>

            </dl>

            <div class="mt-4">

                @using (Html.BeginForm("Delete", "Patients", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <!-- IMPORTANT: Send Patient Id -->
                    @Html.HiddenFor(model => model.Id)

                    <button type="submit" class="btn btn-danger me-2">
                        <i class="bi bi-trash-fill"></i> Delete
                    </button>

                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                }

            </div>

        </div>

    </div>
</div>