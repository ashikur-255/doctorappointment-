@model DoctorAppointmentSystem.Models.Specialization

@{
    ViewBag.Title = "Delete Specialization";
}

<div class="container mt-5">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h4><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h4>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this specialization?</h5>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div class="d-flex justify-content-start mt-3">
                    <input type="submit" value="Delete" class="btn btn-danger me-2" />
                    @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary" })
                </div>
            }
        </div>
    </div>
</div>