@model PagedList.IPagedList<DoctorAppointmentSystem.Models.Specialization>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Specializations";
    string currentSearch = ViewBag.CurrentSearch as string;
    string currentSort = ViewBag.CurrentSort as string;
}

<div class="container mt-4">

    <!-- HEADER -->

    <div class="card shadow border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center"
             style="background:linear-gradient(135deg,#0d6efd,#6f42c1);color:white;">

            <div>
                <h3 class="mb-0">
                    <i class="bi bi-heart-pulse-fill"></i> Specializations Management
                </h3>
                <small>Manage doctor specialization list</small>
            </div>

            <a href="@Url.Action("Create","Specializations")" class="btn btn-light">
                <i class="bi bi-plus-circle"></i> ✚ Add Specialization
            </a>

        </div>
    </div>


    <!-- SEARCH SECTION -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-light fw-bold">
            <i class="bi bi-funnel"></i> Search
        </div>

        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-10">

                    <label class="form-label fw-semibold">Search Specialization</label>

                    <input type="text"
                           id="searchInput"
                           class="form-control"
                           placeholder="Type to filter table..."
                           onkeyup="filterTable()" />

                </div>

                @*<div class="col-md-1 d-grid">

                    <button class="btn btn-primary" onclick="filterTable()">
                        <i class="bi bi-search"></i> Search
                    </button>

                </div>*@

                <div class="col-md-1 d-grid">

                    <button class="btn btn-secondary" onclick="resetFilter()">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>

                </div>

            </div>

        </div>

    </div>


    <!-- TABLE -->

    <div class="card shadow border-0">

        <div class="table-responsive">

            <table id="specializationTable" class="table table-hover align-middle text-center mb-0">

                <thead style="background:linear-gradient(#ffd800);color:blue;">

                    <tr>

                        <th style="width:70%">
                            Specialization Name
                        </th>

                        <th width="220">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="p-5 text-muted">
                                No Specializations Found
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-bold text-primary">
                                    <i class="bi bi-bookmark-check"></i>
                                    @item.Name
                                </td>

                                <td>

                                    <div class="d-flex justify-content-center gap-2">

                                        <a href="@Url.Action("Edit", new { id = item.Id })"
                                           class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <a href="@Url.Action("Details", new { id = item.Id })"
                                           class="btn btn-info btn-sm text-white">
                                            Details
                                        </a>

                                        <a href="@Url.Action("Delete", new { id = item.Id })"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete this specialization?')">
                                            Delete
                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>


    <!-- PAGINATION -->

    <div class="d-flex justify-content-center align-items-center mt-4">

        @if (Model.HasPreviousPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber - 1 })"
               class="btn btn-outline-primary me-2">
                ◀ Previous
            </a>
        }
        else
        {
            <span class="btn btn-outline-secondary disabled me-2">◀ Previous</span>
        }

        <span class="fw-bold mx-2">
            Page @Model.PageNumber of @Model.PageCount
        </span>

        @if (Model.HasNextPage)
        {
            <a href="@Url.Action("Index", new { page = Model.PageNumber + 1 })"
               class="btn btn-outline-primary ms-2">
                Next ▶
            </a>
        }
        else
        {
            <span class="btn btn-outline-secondary disabled ms-2">Next ▶</span>
        }

    </div>

</div>


<!-- JAVASCRIPT AUTO FILTER -->

<script>

    function filterTable() {

        var input = document.getElementById("searchInput");
        var filter = input.value.toLowerCase();

        var table = document.getElementById("specializationTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {

            var td = tr[i].getElementsByTagName("td")[0];

            if (td) {

                var txtValue = td.textContent || td.innerText;

                if (txtValue.toLowerCase().indexOf(filter) > -1) {

                    tr[i].style.display = "";

                } else {

                    tr[i].style.display = "none";

                }

            }

        }

    }


    function resetFilter() {

        document.getElementById("searchInput").value = "";

        var table = document.getElementById("specializationTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {

            tr[i].style.display = "";

        }

    }

</script>