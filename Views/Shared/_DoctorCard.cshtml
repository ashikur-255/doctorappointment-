@model DoctorAppointmentSystem.Models.Doctor

<div class="card shadow-sm text-center p-3 mb-4" style="width: 18rem; display:inline-block; margin-right:15px;">
    <!-- Doctor Image -->
    <img src="@Url.Content(string.IsNullOrEmpty(Model.ImagePath) ? "~/Images/Doctors/default.png" : Model.ImagePath)"
         class="rounded-circle mb-3"
         width="150"
         height="150"
         alt="@Model.Name" />

    <!-- Doctor Name -->
    <h3 class="fw-bold">@Model.Name</h3>

    <!-- Specialization -->
    <p class="text-muted">@Model.Specialization?.Name ?? "No Specialization"</p>

    <!-- Consultation Fee (Optional) -->
    <p class="text-success fw-bold">$@Model.ConsultationFee.ToString("F2")</p>

    <!-- Book Appointment Button -->
    <a href="/Appointments/Create?doctorId=@Model.Id" class="btn btn-success">
        <i class="bi bi-calendar-plus"></i> Book Appointment
    </a>
</div>
