<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Doctor Appointment System</title>

    @Styles.Render("~/Content/css")

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container">

            @Html.ActionLink("👩‍⚕️ Doctor Appointment System", "Index", "Home", null, new { @class = "navbar-brand fw-bold" })

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                <!-- LEFT MENU -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        @Html.ActionLink("Doctors", "Index", "Doctors", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Patients", "Index", "Patients", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Appointments", "Index", "Appointments", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Specializations", "Index", "Specializations", null, new { @class = "nav-link" })
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Admin Dashboard", "Dashboard", "Admin", null, new { @class = "nav-link text-warning" })
                        </li>
                    }

                    @if (User.IsInRole("Doctor"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Doctor Portal", "Dashboard", "DoctorPortal", null, new { @class = "nav-link text-info" })
                        </li>
                    }

                    <li class="nav-item">
                        @Html.ActionLink("About", "About", "Home", null, new { @class = "nav-link" })
                    </li>

                </ul>

                <!-- RIGHT MENU -->
                <ul class="navbar-nav">
                    @if (Request.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                👋 Welcome, @ViewBag.UserName
                            </span>
                        </li>

                        <li class="nav-item">
                            @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm">Logout</button>
                            }
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Login", "Login", "Account", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Register", "Register", "Account", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- ================= BODY ================= -->
    <div class="container mt-4">
        @RenderBody()
        <hr />

        <!-- ================= FOOTER ================= -->
        <footer class="footer-section mt-4">
            <div class="container">
                <div class="row">

                    <!-- About -->
                    <div class="col-md-4">
                        <h5>Doctor Appointment System</h5>
                        <p>
                            Book appointments with trusted doctors easily.
                            Manage schedules and patients efficiently.
                        </p>
                        <p>
                            <strong>Developer:</strong> Ashikur Rahman <br />
                            Dhaka, Bangladesh
                        </p>
                    </div>

                    <!-- Services -->
                    <div class="col-md-4">
                        <h5>Services</h5>
                        <ul class="footer-links">
                            <li>@Html.ActionLink("Find Doctors", "Index", "Doctors")</li>
                            <li>@Html.ActionLink("Book Appointment", "Create", "Appointments")</li>
                            <li>@Html.ActionLink("Specializations", "Index", "Specializations")</li>
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div class="col-md-4">
                        <h5>Contact</h5>
                        <p>📍 Dhaka, Bangladesh</p>
                        <p>📞 +880 1708588330</p>
                        <p>📧 ashikurr255@gmail.com</p>
                    </div>

                </div>

                <hr />

                <div class="text-center">
                    <p>© @DateTime.Now.Year Doctor Appointment System</p>
                </div>
            </div>
        </footer>

    </div>

    <!-- ================= BACK TO TOP ================= -->
    <button onclick="topFunction()" id="topBtn">▲</button>

    <!-- ================= SCRIPTS ================= -->
    @Scripts.Render("~/bundles/jquery")

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

    <script>
        let mybutton = document.getElementById("topBtn");

        window.onscroll = function () {
            if (document.documentElement.scrollTop > 200) {
                mybutton.style.display = "block";
            } else {
                mybutton.style.display = "none";
            }
        };

        function topFunction() {
            document.documentElement.scrollTop = 0;
        }
    </script>

</body>
</html>

<style>
    .footer-section {
        background: #0d6efd;
        color: #fff;
        padding: 40px 0;
    }

    .footer-links {
        list-style: none;
        padding: 0;
    }

        .footer-links li {
            margin-bottom: 8px;
        }

        .footer-links a {
            color: #ddd;
            text-decoration: none;
        }

            .footer-links a:hover {
                color: #fff;
            }

    #topBtn {
        display: none;
        position: fixed;
        bottom: 30px;
        right: 30px;
        border: none;
        background: #0d6efd;
        color: white;
        padding: 10px 14px;
        border-radius: 50%;
        cursor: pointer;
    }

        #topBtn:hover {
            background: #0b5ed7;
        }
</style>