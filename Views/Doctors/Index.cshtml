@model PagedList.IPagedList<DoctorAppointmentSystem.Models.Doctor>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Doctors";
}

<div class="container mt-4">

    <!-- ===== PAGE HEADER ===== -->
    <div class="card shadow border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center"
             style="background:linear-gradient(135deg,#0d6efd,#6f42c1);color:white;">
            <div>
                <h3 class="mb-0"><i class="bi bi-person-badge-fill"></i> Doctors Management</h3>
                <small>Manage doctors information</small>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <a href="@Url.Action("Create","Doctors")" class="btn btn-light">
                    <i class="bi bi-person-plus"></i> ✚ Add Doctor
                </a>
            }
        </div>
    </div>


    <!-- ===== SEARCH FILTER ===== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">
            <i class="bi bi-funnel"></i> Search & Filters
        </div>

        <div class="card-body">

            <div class="row g-3 align-items-end">

                <!-- SEARCH -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text"
                           name="search"
                           value="@ViewBag.CurrentSearch"
                           class="form-control"
                           placeholder="Doctor name or specialization" />
                </div>

                <!-- STATUS -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Status</label>

                    <select name="status" class="form-select">

                        <option value="">All Status</option>

                        <option value="Available"
                                @(ViewBag.CurrentStatus == "Available" ? "selected" : "")>
                            Available
                        </option>

                        <option value="Not Available"
                                @(ViewBag.CurrentStatus == "Not Available" ? "selected" : "")>
                            Not Available
                        </option>

                    </select>
                </div>


                <!-- SPECIALIZATION -->
                <div class="col-md-3">

                    <label class="form-label fw-semibold">Specialization</label>

                    @Html.DropDownList(
                    "specializationId",
                    (ViewBag.Specializations as SelectList),
                    "All Specializations",
                    new { @class = "form-select" })

                </div>


                <!-- RESET -->
                <div class="col-md-3 d-flex">

                    <a href="@Url.Action("Index")" class="btn btn-secondary w-100">
                        Reset
                    </a>

                </div>

            </div>

        </div>
    </div>


    <!-- ============================= -->
    <!-- DOCTOR TABLE CONTAINER (AJAX) -->
    <!-- ============================= -->

    <div id="doctorTableContainer">

        <div class="card shadow border-0">

            <div class="table-responsive">

                <table class="table table-hover table-bordered align-middle text-center mb-0">

                    <thead style="background:#ffd800;color:#0d6efd">

                        <tr>

                            <th>Photo</th>

                            <th>Name</th>

                            <th>Hospital</th>

                            <th>Registration</th>

                            <th>Degree</th>

                            <th>Specialization</th>

                            <th>Experience</th>

                            <th>Fee</th>

                            <th>Visited Time</th>

                            <th>Status</th>

                            <th>Joining Date</th>

                            <th width="220">Actions</th>

                        </tr>

                    </thead>


                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="12" class="p-5 text-muted">
                                    No Doctors Found
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var doctor in Model)
                            {

                                <tr>

                                    <td>
                                        <img src="@(!string.IsNullOrEmpty(doctor.ImagePath)
                                        ? Url.Content(doctor.ImagePath)
                                        : Url.Content("~/Images/Doctors/default.png"))"
                                             class="rounded-circle border shadow-sm"
                                             style="width:60px;height:60px;object-fit:cover" />
                                    </td>

                                    <td class="fw-bold text-primary">
                                        @doctor.Name
                                    </td>

                                    <td>@doctor.HospitalName</td>

                                    <td>@doctor.RegistrationNo</td>

                                    <td>@doctor.Degree</td>

                                    <td>@(doctor.Specialization?.Name ?? "N/A")</td>

                                    <td>
                                        <span class="badge bg-info">
                                            @doctor.ExperienceYears Years
                                        </span>
                                    </td>

                                    <td class="fw-bold text-success">
                                        $@doctor.ConsultationFee
                                    </td>

                                    <td>
                                        @(doctor.VisitedTime.HasValue
                                        ? DateTime.Today.Add(doctor.VisitedTime.Value).ToString("hh:mm tt")
                                        : "N/A")
                                    </td>

                                    <td>

                                        @if (doctor.IsAvailable)
                                        {
                                            <span class="badge bg-success">
                                                Available
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                Not Available
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        @doctor.JoiningDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>

                                        <div class="d-flex justify-content-center gap-2 flex-wrap">

                                            <a href="@Url.Action("Details", new { id = doctor.Id })"
                                               class="btn btn-info btn-sm text-white">
                                                <i class="bi bi-eye"></i> Details
                                            </a>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a href="@Url.Action("Edit", new { id = doctor.Id })"
                                                   class="btn btn-warning btn-sm">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>

                                                <a href="@Url.Action("Delete", new { id = doctor.Id })"
                                                   class="btn btn-danger btn-sm">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            }

                                        </div>

                                    </td>

                                </tr>

                            }
                        }

                    </tbody>

                </table>

            </div>
        </div>


        <!-- ===== PAGINATION ===== -->

        <div class="d-flex justify-content-center align-items-center mt-4">

            @if (Model.HasPreviousPage)
            {
                <a href="#" data-page="@(Model.PageNumber - 1)" class="btn btn-outline-primary page-link me-2">
                    ◀ Previous
                </a>
            }
            else
            {
                <span class="btn btn-outline-secondary disabled me-2">
                    ◀ Previous
                </span>
            }

            <span class="fw-bold mx-2">
                Page @Model.PageNumber of @Model.PageCount
            </span>

            @if (Model.HasNextPage)
            {
                <a href="#" data-page="@(Model.PageNumber + 1)" class="btn btn-outline-primary page-link ms-2">
                    Next ▶
                </a>
            }
            else
            {
                <span class="btn btn-outline-secondary disabled ms-2">
                    Next ▶
                </span>
            }

        </div>

    </div>

</div>



<!-- ===================================== -->
<!-- JQUERY -->
<!-- ===================================== -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    var jQuery = window.jQuery;
    var $ = window.jQuery;

    $(document).ready(function () {

        let searchTimer;

        // =====================================
        // LOAD DOCTORS
        // =====================================
        function loadDoctors(page) {

            page = page || 1;

            var search = $('input[name="search"]').val() || "";
            var status = $('select[name="status"]').val() || "";
            var specializationId = $('select[name="specializationId"]').val() || "";

            // LOADING OVERLAY
            if ($('#loadingOverlay').length === 0) {

                $('#doctorTableContainer').append(

                    '<div id="loadingOverlay" class="table-loading-overlay">' +
                    '<div class="text-center">' +
                    '<div class="spinner-border text-primary"></div>' +
                    '<div class="mt-3 fw-semibold">Loading Doctors...</div>' +
                    '</div>' +
                    '</div>'

                );

            }

            $.ajax({

                url: '@Url.Action("Index", "Doctors")',
                type: 'GET',
                cache: false,

                data: {
                    search: search,
                    status: status,
                    specializationId: specializationId,
                    page: page
                },

                success: function (result) {

                    var html = $('<div>').html(result);

                    var newContent = html.find('#doctorTableContainer').html();

                    if (newContent) {

                        $('#doctorTableContainer').html(newContent);

                    }

                },

                error: function () {

                    $('#doctorTableContainer').html(

                        '<div class="alert alert-danger text-center m-4">' +
                        'Error loading doctor data.' +
                        '</div>'

                    );

                },

                complete: function () {

                    $('#loadingOverlay').remove();

                }

            });

        }

        // =====================================
        // SEARCH WITH DELAY
        // =====================================
        $(document).on('keyup', 'input[name="search"]', function () {

            clearTimeout(searchTimer);

            searchTimer = setTimeout(function () {

                loadDoctors(1);

            }, 500);

        });

        // =====================================
        // STATUS FILTER
        // =====================================
        $(document).on('change', 'select[name="status"]', function () {

            loadDoctors(1);

        });

        // =====================================
        // SPECIALIZATION FILTER
        // =====================================
        $(document).on('change', 'select[name="specializationId"]', function () {

            loadDoctors(1);

        });

        // =====================================
        // PAGINATION
        // =====================================
        $(document).on('click', '.page-link', function (e) {

            e.preventDefault();

            var page = $(this).data('page');

            if (page) {

                loadDoctors(page);

            }

        });

    });

</script>