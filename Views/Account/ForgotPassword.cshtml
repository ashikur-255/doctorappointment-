@model DoctorAppointmentSystem.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "Forgot Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-warning text-dark text-center">
                    <h3 class="mb-0">
                        <i class="bi bi-key"></i> Forgot Password
                    </h3>
                </div>

                <div class="card-body p-4">

                    <p class="text-muted text-center">
                        Enter your email address and we will send you a password reset link.
                    </p>

                    @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

                        <!-- Email -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.Email, new
                            {
                                @class = "form-control",
                                placeholder = "Enter your registered email"
                            })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="bi bi-envelope"></i> Send Reset Link
                            </button>
                        </div>

                        <!-- Back to Login -->
                        <div class="text-center mt-3">
                            <p class="mb-0">
                                Remember your password?
                                @Html.ActionLink("Login", "Login", "Account", null, new { @class = "text-decoration-none fw-semibold" })
                            </p>
                        </div>
                    }

                </div>

            </div>

        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}