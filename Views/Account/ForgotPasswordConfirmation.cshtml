@{
    ViewBag.Title = "Forgot Password Confirmation";
}

<div class="container mt-5 text-center">

    <div class="alert alert-success shadow p-4 rounded-4">
        <h4>✅ Reset Link Generated</h4>
        <p>Please check your email to reset your password.</p>

        @if (TempData["ResetLink"] != null)
        {
            <div class="mt-3">
                <p><strong>Test Link:</strong></p>
                <a href="@TempData["ResetLink"]" class="btn btn-primary">
                    🔗 Reset Password
                </a>
            </div>
        }
    </div>

</div>